# ============================================================
# LogLife — Variáveis de Ambiente
# ============================================================
# 1. Copie este arquivo para .env.local (desenvolvimento)
# 2. No Vercel: Settings → Environment Variables → adicione cada uma abaixo
# ============================================================

# --- Supabase (encontre em: Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# --- App ---
NEXT_PUBLIC_APP_URL=https://log-life-brown.vercel.app

# --- Yampi / Dooki ---
# YAMPI_TOKEN    → Yampi: Configurações → API → User Token
# YAMPI_SECRET   → Yampi: Configurações → API → User Secret Key
# YAMPI_ALIAS    → slug da sua loja (ex: melasonina)
YAMPI_TOKEN=seu_user_token_yampi
YAMPI_SECRET=seu_user_secret_key_yampi
YAMPI_ALIAS=sua_loja_yampi

# --- 3 lojas para o botão Sincronizar ---
YAMPI_ALIAS_1=melasonina
YAMPI_ALIAS_2=dryskin-tratamento-para-o-suor-e-mau-odor-nas-axilas
YAMPI_ALIAS_3=bom-halito-innolife

# --- Chaves secretas dos webhooks Yampi (uma por loja) ---
# Encontre em: Yampi → Configurações → Webhooks → Chave secreta
YAMPI_WEBHOOK_SECRET_1=cole_a_chave_webhook_da_loja_1
YAMPI_WEBHOOK_SECRET_2=cole_a_chave_webhook_da_loja_2
YAMPI_WEBHOOK_SECRET_3=cole_a_chave_webhook_da_loja_3

# ============================================================
# URL do Webhook para configurar na Yampi:
#   https://log-life-brown.vercel.app/api/yampi-webhook
# Método: POST
# ============================================================
